{
  "name": "terminal-hs-game",
  "version": "0.1.0-alpha.1",
  "description": "Educational terminal hacking campaign (safe, sandbox). CLI + browser alpha — Node 18+, MIT.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Orithmic Software (https://github.com/OrithmicSoftware)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OrithmicSoftware/terminal-hs-game.git"
  },
  "bugs": {
    "url": "https://github.com/OrithmicSoftware/terminal-hs-game/issues"
  },
  "homepage": "https://github.com/OrithmicSoftware/terminal-hs-game#readme",
  "keywords": [
    "terminal",
    "game",
    "cli",
    "campaign",
    "hacking-simulation",
    "educational",
    "browser-game"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node game.mjs",
    "game": "node game.mjs",
    "game:clear": "node scripts/run-game-clear.mjs",
    "cipher": "node scripts/run-cipher.mjs",
    "infiltrate": "node scripts/run-infiltrate.mjs",
    "start:clear": "node scripts/run-game-clear.mjs",
    "demo:animate-text": "node scripts/animate-text.mjs --",
    "clear": "npm run dev:clear --prefix web",
    "web:dev": "npm run dev --prefix web",
    "web:dev:clear": "npm run dev:clear --prefix web",
    "web:build": "npm run build --prefix web",
    "test:e2e": "npm run test:e2e --prefix web",
    "test:e2e:terminal": "node --test test/e2e-terminal.test.mjs",
    "test:e2e:scenes": "node --test test/e2e-scenes.test.mjs",
    "test:cli-e2e": "node --test test/cli-e2e.test.mjs",
    "checkpoint:list": "node scripts/checkpoint-list.mjs",
    "repo:github-meta": "node scripts/github-repo-meta.mjs",
    "repo:gh-edit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/gh-repo-edit-meta.ps1",
    "test": "node --test test/campaign-state.test.mjs test/debug-scene.test.mjs test/engine-mail.test.mjs test/e2e-terminal.test.mjs test/e2e-scenes.test.mjs test/cli-e2e.test.mjs test/cipher-cli.test.mjs test/mini-games.test.mjs test/ghost-chat-animation.test.mjs test/web-landing.test.mjs"
  }
}
